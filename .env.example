# PostgreSQL connection settings (local defaults are safe for Postgres.app/Homebrew)
PGHOST=localhost
PGPORT=5432
PGDATABASE=mindlift

# Optional overrides (uncomment if needed)
# PGUSER=your_local_postgres_user
# PGPASSWORD=your_postgres_password
# PGADMIN_DATABASE=postgres

# SQLAlchemy URL overrides (optional)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/mindlift
# DATABASE_ADMIN_URL=postgresql+psycopg2://user:password@localhost:5432/postgres

# Optional S3 settings
# S3_BUCKET=your-bucket-name
# S3_PREFIX=mindlift/raw
# AWS_REGION=us-east-1
